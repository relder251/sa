# Required paths
COMPOSE_DIR=/opt/agentic-sdlc
COMPOSE_SERVICE=twingate
ENV_FILE=/opt/agentic-sdlc/.env

# Existing rotation command from your automation bundle.
ROTATE_COMMAND=/opt/agentic-sdlc/scripts/twingate/rotate-twingate-connector.sh --verbose

# Trigger behavior
LOG_LINES=200
LOOKBACK_SECONDS=900
EXPIRY_THRESHOLD_SECONDS=86400
FAIL_THRESHOLD=3

# Optional
STATE_FILE=/var/lib/twingate-connector-guard/state.env
LOCK_FILE=/var/lock/twingate-connector-guard.lock
VERBOSE=1
DRY_RUN=0
FORCE_ROTATE=0
