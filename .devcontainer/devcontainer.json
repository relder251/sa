{
  "name": "SA Stack — Test Tooling",

  // Build from a Dockerfile so the base image is a FROM line that Codespaces
  // cannot normalise.  Using "image": directly causes Codespaces to strip the
  // "-bookworm" variant tag (3.11-bookworm → 3.11), which resolves to Debian
  // trixie.  The docker-outside-of-docker feature that Codespaces injects
  // automatically fails on trixie because moby-cli was removed from that
  // distribution.  With a Dockerfile the FROM line is never touched, so we
  // always land on bookworm where moby works fine.
  "build": {
    "dockerfile": "Dockerfile"
  },

  // Docker socket mount — for VS Code Remote Containers (local) only.
  // In Codespaces this mounts the Codespace's own Docker daemon (not the host VPS).
  // Uncomment if running locally with VS Code Remote Containers.
  // "mounts": [
  //   "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  // ],

  "features": {
    // Gives us git, curl, jq out of the box
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "configureZshAsDefaultShell": false
    }
  },

  // Run after container creation: install Python test dependencies + Chromium
  "postCreateCommand": "bash .devcontainer/setup.sh",

  // Forward ports used by smoke tests when the stack is reachable
  "forwardPorts": [4000, 5678, 3000, 5003, 8888],
  "portsAttributes": {
    "4000": { "label": "LiteLLM" },
    "5678": { "label": "n8n" },
    "3000": { "label": "Web UI" },
    "5003": { "label": "Lead Review" },
    "8888": { "label": "JupyterLab" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-playwright.playwright",
        "timonwong.shellcheck",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"],
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
