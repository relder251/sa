{
  "name": "SA Stack — Test Tooling",

  // Pin to the exact Debian bookworm image via SHA digest — no tag string
  // for Codespaces to normalise.  The problem: Codespaces CLI 0.80.3 strips
  // the "-bookworm" variant suffix from any tag (3.11-bookworm → 3.11), and
  // the untagged :3.11 image resolves to Debian trixie where moby-cli is
  // absent.  A tag-less digest reference (@sha256:...) has nothing to strip.
  //
  // Digest verified: mcr.microsoft.com/devcontainers/python:3.11-bookworm
  // on linux/amd64 → sha256:aea59f6834231486ee510ed90fc89659762e8ac246bb5e5fc49809ab736a0b94
  "image": "mcr.microsoft.com/devcontainers/python@sha256:aea59f6834231486ee510ed90fc89659762e8ac246bb5e5fc49809ab736a0b94",

  // Docker socket mount — for VS Code Remote Containers (local) only.
  // In Codespaces this mounts the Codespace's own Docker daemon (not the host VPS).
  // Uncomment if running locally with VS Code Remote Containers.
  // "mounts": [
  //   "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  // ],

  "features": {
    // Gives us git, curl, jq out of the box
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "configureZshAsDefaultShell": false
    },

    // Belt-and-suspenders: if Codespaces somehow still injects trixie,
    // moby:false makes the feature install docker-ce instead of moby-cli.
    // docker-ce IS supported on trixie (in DOCKER_LICENSED_ARCHIVE_VERSION_CODENAMES).
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    }
  },

  // Run after container creation: install Python test dependencies + Chromium
  "postCreateCommand": "bash .devcontainer/setup.sh",

  // Forward ports used by smoke tests when the stack is reachable
  "forwardPorts": [4000, 5678, 3000, 5003, 8888],
  "portsAttributes": {
    "4000": { "label": "LiteLLM" },
    "5678": { "label": "n8n" },
    "3000": { "label": "Web UI" },
    "5003": { "label": "Lead Review" },
    "8888": { "label": "JupyterLab" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-playwright.playwright",
        "timonwong.shellcheck",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"],
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
