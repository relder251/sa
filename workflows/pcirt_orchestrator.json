  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "pcirt-push",
        "options": {
          "responseMode": "lastNode"
        }
      },
      "id": "git-push-webhook",
      "name": "Git Push Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        200,
        200
      ],
      "webhookId": "pcirt-push"
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 3 * * *"
            }
          ]
        }
      },
      "id": "cron-daily-audit",
      "name": "Cron Daily Audit",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        200,
        400
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "trigger-type",
              "name": "trigger",
              "value": "={{ $json.trigger || ($json.commit ? 'git-push' : 'cron') }}",
              "type": "string"
            },
            {
              "id": "commit-hash",
              "name": "commit",
              "value": "={{ $json.commit || 'HEAD' }}",
              "type": "string"
            },
            {
              "id": "branch-name",
              "name": "branch",
              "value": "={{ $json.branch || 'master' }}",
              "type": "string"
            },
            {
              "id": "project-slug",
              "name": "project",
              "value": "agentic-sdlc",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "set-trigger-context",
      "name": "Set Trigger Context",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        440,
        300
      ]
    },
    {
      "parameters": {
        "command": "cd /opt/agentic-sdlc && claude --project /opt/agentic-sdlc -p \"You are the OpenClaw AUDIT agent for the agentic-sdlc project. Read /opt/agentic-sdlc/.openclaw/agents/agentic-sdlc/audit.md and follow the audit protocol exactly. Project root: /opt/agentic-sdlc. SRC_DIR: /opt/agentic-sdlc. Project slug: agentic-sdlc. DEP_AUDIT_CMD: pip check 2>/dev/null || true. Run all four audit passes (Security, Logic, Documentation, Dependency). Write findings to /opt/agentic-sdlc/AUDIT.md (append). Write CRITICAL/HIGH items to /opt/agentic-sdlc/CYCLE-TASKS.md. Output a summary of findings.\" --output-format text 2>&1 || echo 'AUDIT_AGENT_ERROR: claude not available - manual audit required'"
      },
      "id": "run-audit-agent",
      "name": "Run Audit Agent",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has-critical",
              "leftValue": "={{ $json.stdout }}",
              "rightValue": "CRITICAL",
              "operator": {
                "type": "string",
                "operation": "contains"
              }
            },
            {
              "id": "has-high",
              "leftValue": "={{ $json.stdout }}",
              "rightValue": "HIGH",
              "operator": {
                "type": "string",
                "operation": "contains"
              }
            }
          ],
          "combinator": "or"
        },
        "options": {}
      },
      "id": "check-severity",
      "name": "Check for CRITICAL or HIGH",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        920,
        300
      ]
    },
    {
      "parameters": {
        "command": "cd /opt/agentic-sdlc && CYCLE_ID=$(date +%Y%m%d-%H%M) && claude --project /opt/agentic-sdlc -p \"You are the OpenClaw BREAK-FIX agent for the agentic-sdlc project. Read /opt/agentic-sdlc/.openclaw/agents/agentic-sdlc/break-fix.md and follow the Stage 1 (PROPOSE) protocol exactly. Project root: /opt/agentic-sdlc. CYCLE_ID: ${CYCLE_ID}. Read /opt/agentic-sdlc/AUDIT.md and extract CRITICAL/HIGH findings. For each finding: read the affected file in full, draft a minimal targeted patch, write the patch to /opt/agentic-sdlc/.patches/${CYCLE_ID}-{slug}.patch in git diff format, write a proposal to /opt/agentic-sdlc/.patches/${CYCLE_ID}-{slug}.proposal.md. STOP after writing proposals \u2014 do NOT apply any changes to source files. Output a summary of proposals written.\" --output-format text 2>&1 || echo 'BREAKFIX_AGENT_ERROR: claude not available - manual review required'"
      },
      "id": "run-breakfix-stage1",
      "name": "Run Break-Fix Stage 1",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        1160,
        180
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.notion.com/v1/pages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer ntn_REDACTED"
            },
            {
              "name": "Notion-Version",
              "value": "2022-06-28"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"parent\":{\"type\":\"page_id\",\"page_id\":\"32b99de0e9dd81f786fce90fdc2636fe\"},\"properties\":{\"title\":{\"title\":[{\"text\":{\"content\":\"PCIRT Alert: agentic-sdlc CRITICAL/HIGH \u2014 \" + new Date().toISOString()}}]}},\"children\":[{\"object\":\"block\",\"type\":\"paragraph\",\"paragraph\":{\"rich_text\":[{\"type\":\"text\",\"text\":{\"content\":\"Patch proposals written to .patches/. Approve: touch .patches/{filename}.APPROVED\\n\\nAudit:\\n\" + ($('run-audit-agent').item.json.stdout || '').slice(0,1800) + \"\\n\\nBreak-fix:\\n\" + ($json.stdout || '').slice(0,800)}}]}}]}",
        "options": {}
      },
      "id": "notify-hitl-proposal",
      "name": "Notify HITL \u2014 Patch Proposal Ready",
