        {
            "id": "query-notion",
            "name": "Query Notion for Ready Tasks",
            "type": "n8n-nodes-base.httpRequest",
            "position": [
                420,
                300
            ],
            "parameters": {
                "url": "https://api.notion.com/v1/databases/f7f99de0-e9dd-8342-9d79-81a93b571dfc/query",
                "method": "POST",
                "options": {},
                "jsonBody": "{\n  \"filter\": {\n    \"and\": [\n      {\n        \"property\": \"Status\",\n        \"status\": {\n          \"equals\": \"Ready\"\n        }\n      },\n      {\n        \"property\": \"Agent blocked\",\n        \"checkbox\": {\n          \"equals\": false\n        }\n      }\n    ]\n  },\n  \"sorts\": [\n    {\n      \"timestamp\": \"created_time\",\n      \"direction\": \"ascending\"\n    }\n  ]\n}",
                "sendBody": true,
                "contentType": "json",
                "sendHeaders": true,
                "specifyBody": "json",
                "authentication": "genericCredentialType",
                "genericAuthType": "httpHeaderAuth",
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "Notion-Version",
                            "value": "2022-06-28"
                        }
                    ]
                }
            },
            "credentials": {
                "httpHeaderAuth": {
                    "id": "Fd9gwjnr6Vi7sRUN",
                    "name": "Notion Tasks API"
                }
            },
            "typeVersion": 4.2
        },
        {
            "id": "has-tasks",
            "name": "Has Ready Tasks?",
            "type": "n8n-nodes-base.if",
            "position": [
                640,
                300
            ],
            "parameters": {
                "options": {},
                "conditions": {
                    "options": {
                        "leftValue": "",
                        "caseSensitive": true,
                        "typeValidation": "strict"
                    },
                    "combinator": "and",
                    "conditions": [
                        {
                            "id": "has-results",
                            "operator": {
                                "type": "number",
                                "operation": "gt"
                            },
                            "leftValue": "={{ $json.results.length }}",
                            "rightValue": 0
                        }
                    ]
                }
            },
            "typeVersion": 2.2
        },
        {
            "id": "split-results",
            "name": "Split Into Individual Tasks",
            "type": "n8n-nodes-base.splitOut",
            "position": [
                860,
                200
            ],
            "parameters": {
                "options": {},
                "fieldToSplitOut": "results"
            },
            "typeVersion": 1
        },
        {
            "id": "extract-task-data",
            "name": "Extract Task Data",
            "type": "n8n-nodes-base.set",
            "position": [
                1080,
                200
            ],
            "parameters": {
                "options": {},
