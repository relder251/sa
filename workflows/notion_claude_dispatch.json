                        },
                        {
                            "id": "pass-prompt",
                            "name": "prompt",
                            "type": "string",
                            "value": "={{ $('Extract Task Data').item.json.prompt }}"
                        },
                        {
                            "id": "pass-task-name",
                            "name": "task_name",
