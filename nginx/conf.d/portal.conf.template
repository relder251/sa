server {
    listen 80;
    server_name home.private.sovereignadvisory.ai;

    root /usr/share/nginx/html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # LiteLLM provider health — used by portal for API access badges
    # Must appear before /api/ to make ordering intent explicit
    # (nginx longest-match prefix means /api/litellm-health always wins over /api/)
    location /api/litellm-health {
        proxy_pass http://litellm:4000/health/services;
        proxy_set_header Host $host;
        # LITELLM_API_KEY is injected by nginx:alpine envsubst at container start.
        # Set LITELLM_API_KEY in the portal service environment in docker-compose.
        proxy_set_header Authorization "Bearer ${LITELLM_API_KEY}";
    }

    # portal data API — returns live services.json via n8n (GET, no body required)
    location /api/portal-services {
        proxy_pass http://n8n:5678/webhook/VHUS5Dx1q9HBZPln/webhook/portal-services;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 10s;
    }

    # n8n provisioning webhooks
    # portal-provision uses workflowId-prefixed path (n8n 2.12.x internal format)
    # the 3 newer workflows use plain /webhook/{path} format

    location /api/portal-provision {
        proxy_pass http://n8n:5678/webhook/DXjMzKwRB6c54GCY/webhook/portal-provision;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 120s;
    }

    location /api/portal-update-categories {
        proxy_pass http://n8n:5678/webhook/portal-update-categories;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 30s;
    }

    location /api/portal-update {
        proxy_pass http://n8n:5678/webhook/portal-update;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 30s;
    }

    location /api/portal-delete {
        proxy_pass http://n8n:5678/webhook/portal-delete;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 30s;
    }

    location /api/portal-track-recent {
        proxy_pass http://n8n:5678/webhook/portal-track-recent;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 10s;
    }
}
