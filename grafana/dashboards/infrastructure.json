          "refId": "B",
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "container_memory_usage_bytes{job=\"cadvisor\",name!=\"\",image!=\"\"} / clamp_min(container_memory_limit_bytes{job=\"cadvisor\",name!=\"\",image!=\"\"},1) * 100",
          "instant": true,
          "legendFormat": "{{name}}",
          "refId": "C",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": ["name", "Value #A", "Value #B", "Value #C"]
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "name": "Container",
              "Value #A": "CPU %",
              "Value #B": "Memory MB",
              "Value #C": "Memory %"
            }
          }
        }
      ]
