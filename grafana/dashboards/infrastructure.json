          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "avg(rate(node_cpu_seconds_total{job=\"node\",mode=\"system\"}[$__rate_interval])) * 100",
          "legendFormat": "System",
          "refId": "B"
