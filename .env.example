# =============================================================================
# .env.example — ALL VARIABLES DOCUMENTED, NO SECRETS
# Copy to .env.local (local dev), .env.test (test), .env.prod (production).
# DO NOT commit files with real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
LITELLM_USER=litellm
LITELLM_PASSWORD=your-db-password-here
LITELLM_DB=litellm

# -----------------------------------------------------------------------------
# LiteLLM
# -----------------------------------------------------------------------------
LITELLM_API_KEY=your-litellm-master-key-here

# -----------------------------------------------------------------------------
# AI Provider API Keys (same in all envs — set your real keys)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here
GOOGLE_API_KEY=your-google-ai-studio-key-here
DEEPSEEK_API_KEY=your-deepseek-key-here
GROQ_API_KEY=your-groq-key-here
MISTRAL_API_KEY=your-mistral-key-here
OPENROUTER_API_KEY=your-openrouter-key-here
SAMBANOVA_API_KEY=your-sambanova-key-here
PERPLEXITY_API_KEY=your-perplexity-key-here
VENICE_API_KEY=your-venice-user-key-here
VENICE_ADMIN_API_KEY=your-venice-admin-key-here
HUGGINGFACE_API_KEY=your-huggingface-key-here

# Optional: remote Ollama instance
OLLAMA_CLOUD_API_BASE=http://localhost:11434
OLLAMA_CLOUD_API_KEY=ollama

# -----------------------------------------------------------------------------
# Environment / Domain (CHANGE PER ENV)
# -----------------------------------------------------------------------------
# local:  localhost / http
# prod:   sovereignadvisory.ai / https
# test:   test.sovereignadvisory.ai / https
PROTOCOL=http
DOMAIN=localhost

# Keycloak
KC_START_CMD=start-dev
KC_HOSTNAME=localhost
KEYCLOAK_ADMIN_PASSWORD=your-keycloak-admin-password-here
KEYCLOAK_ISSUER_URL=http://keycloak:8080
KEYCLOAK_EXTERNAL_URL=http://localhost:8080

# n8n
N8N_BASE_URL=http://localhost:5678
N8N_HOSTNAME=localhost
N8N_PROTOCOL=http
N8N_SECURE_COOKIE=false
N8N_ENCRYPTION_KEY=your-n8n-encryption-key-here
N8N_OIDC_CLIENT_SECRET=your-n8n-oidc-secret-here

# oauth2-proxy
OAUTH2_COOKIE_SECURE=false
OAUTH2_PROXY_COOKIE_SECRET=your-32-char-cookie-secret-here
OAUTH2_PROXY_COOKIE_SECRET_WEBUI=your-32-char-cookie-secret-webui
OAUTH2_PROXY_COOKIE_SECRET_A0=your-32-char-cookie-secret-a0

# Per-service redirect URLs
LITELLM_REDIRECT_URL=http://localhost:4001/oauth2/callback
N8N_REDIRECT_URL=http://localhost:5679/oauth2/callback
JUPYTER_REDIRECT_URL=http://localhost:8889/oauth2/callback
WEBUI_REDIRECT_URL=http://localhost:3001/oauth2/callback
A0_REDIRECT_URL=http://localhost:50081/oauth2/callback
PORTAL_REDIRECT_URL=http://localhost:4185/oauth2/callback

# OIDC client secrets (configure in Keycloak realm)
LITELLM_OIDC_CLIENT_SECRET=your-litellm-oidc-secret-here
JUPYTER_OIDC_CLIENT_SECRET=your-jupyter-oidc-secret-here
WEBUI_OIDC_CLIENT_SECRET=your-webui-oidc-secret-here
PORTAL_OIDC_CLIENT_SECRET=your-portal-oidc-secret-here
AGENT_ZERO_OIDC_CLIENT_SECRET=your-agent-zero-oidc-secret-here
LEAD_REVIEW_OIDC_CLIENT_SECRET=your-lead-review-oidc-secret-here
VAULTWARDEN_OIDC_CLIENT_SECRET=your-vaultwarden-oidc-secret-here

# Lead Review / portal
LEAD_REVIEW_PASSWORD=your-lead-review-password-here
LEAD_REVIEW_BASE_URL=http://localhost:5003/review
LEAD_REVIEW_PUBLIC_URL=http://localhost:5003
OIDC_ENABLED=false
WEBUI_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# JupyterLab
# -----------------------------------------------------------------------------
JUPYTER_TOKEN=your-jupyter-token-here

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=your-grafana-password-here

# -----------------------------------------------------------------------------
# Notifications (Twilio, Telegram, SMTP)
# -----------------------------------------------------------------------------
NOTIFY_EMAIL=your@email.com
NOTIFY_SMS_EMAIL=
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_SMS_FROM=+1xxxxxxxxxx
NOTIFY_SMS_TO=+1xxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_NOTIFY_TO=whatsapp:+1xxxxxxxxxx
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# SMTP (Resend)
NEO_SMTP_HOST=smtp.resend.com
NEO_SMTP_PORT=465
NEO_SMTP_USER=resend
NEO_SMTP_PASS=your-resend-api-key-here

# -----------------------------------------------------------------------------
# Notion
# -----------------------------------------------------------------------------
NOTION_API_KEY=your-notion-api-key-here
NOTION_PARENT_PAGE_ID=your-notion-parent-page-id
NOTION_LEADS_DB_ID=your-notion-leads-db-id

# -----------------------------------------------------------------------------
# Pipeline / Deployment
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=
DOCKER_REGISTRY=
GIT_REMOTE_URL=
DEPLOY_TARGET=skip
DEPLOY_SSH_HOST=
DEPLOY_SSH_USER=
DEPLOY_SSH_KEY_PATH=
ENABLE_APPROVAL_GATE=false
APPROVAL_TIMEOUT_HOURS=24

# -----------------------------------------------------------------------------
# Cloudflare (for certbot-dns wildcard certs)
# -----------------------------------------------------------------------------
CF_API_TOKEN=your-cloudflare-api-token-here

# -----------------------------------------------------------------------------
# Twingate (prod/test only)
# -----------------------------------------------------------------------------
TWINGATE_NETWORK=your-twingate-network-name
TWINGATE_ACCESS_TOKEN=your-twingate-access-token
TWINGATE_REFRESH_TOKEN=your-twingate-refresh-token
TWINGATE_API_KEY=your-twingate-api-key
TWINGATE_LOG_LEVEL=3
TWINGATE_LABEL_HOSTNAME=your-server-hostname
TWINGATE_TENANT_NAME=your-twingate-tenant

# -----------------------------------------------------------------------------
# Vaultwarden (prod/test only)
# -----------------------------------------------------------------------------
VAULTWARDEN_ADMIN_TOKEN=your-vaultwarden-admin-token

# -----------------------------------------------------------------------------
# n8n API (for external integrations)
# -----------------------------------------------------------------------------
N8N_API_KEY=your-n8n-api-key

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------
SDLC_SCRIPTS_DIR=/opt/agentic-sdlc/scripts
SDLC_OUTPUT_DIR=/opt/agentic-sdlc/output
SA_LOGO_PATH=/opt/agentic-sdlc/www/logo.png

# -----------------------------------------------------------------------------
# Test environment domain (docker-compose.test.yml only)
# -----------------------------------------------------------------------------
TEST_DOMAIN=test.sovereignadvisory.ai
