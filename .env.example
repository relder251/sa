################################################################################
# .env.example — Agentic SDLC environment variables
# Copy to .env and fill in your values before starting the stack.
# .env is gitignored. This file (.env.example) is committed as documentation.
################################################################################

# ── PROXY ─────────────────────────────────────────────────────────────────────
LITELLM_API_KEY=

# ── ANTHROPIC ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── OPENAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── GOOGLE ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GOOGLE_API_KEY=

# ── DEEPSEEK ──────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=

# ── GROQ ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=

# ── MISTRAL ───────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=

# ── OPENROUTER ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ── SAMBANOVA ─────────────────────────────────────────────────────────────────
SAMBANOVA_API_KEY=

# ── PERPLEXITY ────────────────────────────────────────────────────────────────
PERPLEXITY_API_KEY=

# ── VENICE AI ─────────────────────────────────────────────────────────────────
VENICE_API_KEY=
VENICE_ADMIN_API_KEY=

# ── HUGGING FACE ──────────────────────────────────────────────────────────────
HUGGINGFACE_API_KEY=

# ── OLLAMA CLOUD (remote Ollama instance) ─────────────────────────────────────
# Defaults: http://ollama:11434 / "ollama" — override for a remote instance
OLLAMA_CLOUD_API_BASE=
OLLAMA_CLOUD_API_KEY=

# ── N8N ───────────────────────────────────────────────────────────────────────
# Homelab (docker-compose.yml) — uses these var names:
N8N_WEBHOOK_URL=          # e.g. http://localhost:5678
N8N_HOST=                 # e.g. localhost
N8N_PROTOCOL=             # e.g. http
N8N_EDITOR_BASE_URL=      # e.g. http://localhost:5678
# VPS (docker-compose.prod.yml) — uses these var names instead:
N8N_PUBLIC_BASE_URL=      # e.g. https://n8n.private.sovereignadvisory.ai
N8N_PRIVATE_HOSTNAME=     # e.g. n8n.private.sovereignadvisory.ai
# Shared:
N8N_API_KEY=              # Personal API token — n8n Settings > API > Personal API tokens
WF_ID=                    # Workflow ID for deploy_workflow.sh (find: docker exec n8n n8n list:workflow)
N8N_ENCRYPTION_KEY=       # Required — generate: openssl rand -hex 32

# ── POSTGRES CREDENTIALS ──────────────────────────────────────────────────────
LITELLM_USER=
LITELLM_PASSWORD=
LITELLM_DB=

# ── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL=             # postgresql://${LITELLM_USER}:${LITELLM_PASSWORD}@postgres:5432/${LITELLM_DB}
JUPYTER_TOKEN=            # Required — generate: openssl rand -hex 32

# ── PIPELINE PHASES 5-10 ──────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
DOCKER_REGISTRY=
GIT_REMOTE_URL=
DEPLOY_TARGET=            # e.g. skip | ssh | registry
DEPLOY_SSH_HOST=
DEPLOY_SSH_USER=
DEPLOY_SSH_KEY_PATH=
ENABLE_APPROVAL_GATE=     # true | false
APPROVAL_TIMEOUT_HOURS=   # e.g. 24
WEBUI_BASE_URL=

# ── SOVEREIGN ADVISORY LEAD PIPELINE ─────────────────────────────────────────
LEAD_REVIEW_PASSWORD=
LEAD_REVIEW_BASE_URL=
# Notifications
NOTIFY_EMAIL=
NOTIFY_SMS_TO=            # Homelab (docker-compose.yml) — SMS-to-email address
NOTIFY_SMS_EMAIL=         # VPS (docker-compose.prod.yml) — same purpose, different var name
# Telegram (create bot via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Twilio (SMS + WhatsApp sandbox)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=
WHATSAPP_NOTIFY_TO=
# SMTP (outbound notifications)
NEO_SMTP_HOST=
NEO_SMTP_PORT=
NEO_SMTP_USER=
NEO_SMTP_PASS=
# Notion
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=
NOTION_LEADS_DB_ID=
# URLs used inside containers
N8N_BASE_URL=
LITELLM_BASE_URL=

# ── KEYCLOAK SSO ───────────────────────────────────────────────────────────────
OIDC_ENABLED=
KEYCLOAK_ADMIN_PASSWORD=
# Public base URL for lead-review OIDC callback
# Homelab:    LEAD_REVIEW_PUBLIC_URL=http://localhost:5003
# Production: LEAD_REVIEW_PUBLIC_URL=https://sovereignadvisory.ai
LEAD_REVIEW_PUBLIC_URL=
# External Keycloak URL visible from browser
# Homelab:    KEYCLOAK_EXTERNAL_URL=http://localhost:8080
# Production: KEYCLOAK_EXTERNAL_URL=https://kc.sovereignadvisory.ai
KEYCLOAK_EXTERNAL_URL=
# Per-client OIDC secrets (set in Keycloak after creating each client)
N8N_OIDC_CLIENT_SECRET=
WEBUI_OIDC_CLIENT_SECRET=
LITELLM_OIDC_CLIENT_SECRET=
JUPYTER_OIDC_CLIENT_SECRET=
LEAD_REVIEW_OIDC_CLIENT_SECRET=
VAULTWARDEN_OIDC_CLIENT_SECRET=
PORTAL_OIDC_CLIENT_SECRET=
VAULTWARDEN_ADMIN_TOKEN=  # generate: openssl rand -base64 48
OAUTH2_PROXY_COOKIE_SECRET=
OAUTH2_PROXY_COOKIE_SECRET_WEBUI=

# ── VPS-ONLY (docker-compose.prod.yml) ────────────────────────────────────────
# Twingate connector
TWINGATE_NETWORK=         # e.g. yournetwork.twingate.com
TWINGATE_ACCESS_TOKEN=
TWINGATE_REFRESH_TOKEN=
# Lead-review paths (have defaults — only set if non-standard)
# SDLC_SCRIPTS_DIR=/opt/agentic-sdlc/scripts
# SDLC_OUTPUT_DIR=/opt/agentic-sdlc/output
# SA_LOGO_PATH=/opt/sovereignadvisory/www/logo.png
# Certbot DNS-01 challenge (wildcard certs via Cloudflare)
# CF_API_TOKEN=           # Required for certbot-dns renewal — get from Cloudflare dashboard

# ── OPTIONAL / MONITORING ─────────────────────────────────────────────────────
# WATCHTOWER_NOTIFICATION_URL=  # e.g. slack://... — see containrrr/shoutrrr for formats

# ── EXTERNAL TOOL INTEGRATIONS ────────────────────────────────────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=
LINEAR_API_KEY=
POSTMAN_API_KEY=
GREPTILE_API_KEY=
