################################################################################
# .env — LiteLLM provider keys
# Copy to ~/.litellm/.env or source before starting the proxy.
# NEVER commit this file to git.  Add .env to your .gitignore.
################################################################################
# ── PROXY ─────────────────────────────────────────────────────────────────────
LITELLM_API_KEY=
# ── ANTHROPIC ─────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY=
# ── OPENAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# ── GOOGLE ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GOOGLE_API_KEY=
# ── DEEPSEEK ──────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
# ── GROQ ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
# ── MISTRAL ───────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=
# ── OPENROUTER ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
# ── SAMBANOVA ─────────────────────────────────────────────────────────────────
SAMBANOVA_API_KEY=
# ── PERPLEXITY ────────────────────────────────────────────────────────────────
PERPLEXITY_API_KEY=
# ── VENICE AI ─────────────────────────────────────────────────────────────────
VENICE_API_KEY=
VENICE_ADMIN_API_KEY=
# ── HUGGING FACE ──────────────────────────────────────────────────────────────
HUGGINGFACE_API_KEY=
# ── OLLAMA LOCAL ──────────────────────────────────────────────────────────────
# Local instance typically needs no key — just leave the api_base pointing to localhost
# OLLAMA_LOCAL_API_KEY=
# ── OLLAMA CLOUD (VPS) ────────────────────────────────────────────────────────
# OLLAMA_CLOUD_API_BASE=
# OLLAMA_CLOUD_API_KEY=
# HIGGSFIELD ID=
# HIGGSFIELD API KEY SECRET=
# ── N8N ───────────────────────────────────────────────────────────────────────
# n8n URL config — override for VPS (set to Twingate private FQDN)
N8N_WEBHOOK_URL=
N8N_HOST=
N8N_PROTOCOL=
N8N_EDITOR_BASE_URL=
N8N_API_KEY=
N8N_ENCRYPTION_KEY=
# ── POSTGRES CREDENTIALS ──────────────────────────────────────────────────────
LITELLM_USER=
LITELLM_PASSWORD=
LITELLM_DB=
# ── OPTIONAL: database for spend tracking ─────────────────────────────────────
DATABASE_URL=
JUPYTER_TOKEN=        # Required — set a strong random token (e.g. openssl rand -hex 32)
# ── PIPELINE PHASES 5-10 ──────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
DOCKER_REGISTRY=
GIT_REMOTE_URL=
DEPLOY_TARGET=
DEPLOY_SSH_HOST=
DEPLOY_SSH_USER=
DEPLOY_SSH_KEY_PATH=
ENABLE_APPROVAL_GATE=
APPROVAL_TIMEOUT_HOURS=
WEBUI_BASE_URL=
# ── SOVEREIGN ADVISORY LEAD PIPELINE ─────────────────────────────────────────
LEAD_REVIEW_PASSWORD=
LEAD_REVIEW_BASE_URL=
# Notifications
NOTIFY_EMAIL=
TWILIO_SMS_FROM=
NOTIFY_SMS_TO=
# Telegram (create bot via @BotFather; run setup_lead_pipeline.py for instructions)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Twilio (SMS + WhatsApp sandbox)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
WHATSAPP_NOTIFY_TO=
# Resend SMTP (outbound notifications — Neo.space handles inbound MX)
NEO_SMTP_HOST=
NEO_SMTP_PORT=
NEO_SMTP_USER=
NEO_SMTP_PASS=
# Notion (create integration at notion.so/my-integrations; share SA Leads DB with it)
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=
NOTION_LEADS_DB_ID=
# SA PostgreSQL (used by lead pipeline — separate from LiteLLM DB if desired)
# SA_DATABASE_URL=
N8N_BASE_URL=
LITELLM_BASE_URL=
# ── KEYCLOAK SSO ───────────────────────────────────────────────────────────────
# Phase 1: human user login to n8n, lead-review, LiteLLM, JupyterLab
# Set OIDC_ENABLED=
OIDC_ENABLED=
KEYCLOAK_ADMIN_PASSWORD=
# Public base URL for the lead-review portal — used to build the OIDC callback URL.
# LOCAL:      LEAD_REVIEW_PUBLIC_URL=
# PRODUCTION: LEAD_REVIEW_PUBLIC_URL=
LEAD_REVIEW_PUBLIC_URL=
# External Keycloak URL visible from browser.
# LOCAL:      KEYCLOAK_EXTERNAL_URL=
# PRODUCTION: KEYCLOAK_EXTERNAL_URL=
KEYCLOAK_EXTERNAL_URL=
# Per-client OIDC secrets (set these in Keycloak after creating each client)
N8N_OIDC_CLIENT_SECRET=
WEBUI_OIDC_CLIENT_SECRET=
LITELLM_OIDC_CLIENT_SECRET=
JUPYTER_OIDC_CLIENT_SECRET=
LEAD_REVIEW_OIDC_CLIENT_SECRET=
VAULTWARDEN_OIDC_CLIENT_SECRET=
OAUTH2_PROXY_COOKIE_SECRET=
OAUTH2_PROXY_COOKIE_SECRET_WEBUI=
# GitHub / Antigravity / External Tools
GITHUB_PERSONAL_ACCESS_TOKEN=
LINEAR_API_KEY=
POSTMAN_API_KEY=
GREPTILE_API_KEY=
